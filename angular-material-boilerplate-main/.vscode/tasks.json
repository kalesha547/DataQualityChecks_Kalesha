{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "label": "react:install",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "cd /d d:\\Projects\\angular-material-boilerplate-main-react && npm install"
      ]
    },
    {
      "label": "react:build",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "cd /d d:\\Projects\\angular-material-boilerplate-main-react && npm run build"
      ]
    },
    {
      "label": "react:dev",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "cd /d d:\\Projects\\angular-material-boilerplate-main-react && npm run dev"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "Local:"
          }
        }
      }
    }
  ]
}
