# Web API base URL (.NET project)
API_BASE_URL=https://localhost:7129

# Absolute path to the folder containing your PDF files
# Point this to a folder inside your API project (or anywhere on disk)
# Examples:
#   Windows : PDF_FOLDER=C:\Users\you\source\MyApi\pdfs
#   Forward : PDF_FOLDER=C:/Users/you/source/MyApi/pdfs
PDF_FOLDER=C:\path\to\your\api-project\pdfs
